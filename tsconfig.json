{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": false,
        "noEmit": true,
        "allowJs": false,
        "skipLibCheck": true
    },
    "include": ["src/**/*"]
}
