    "license": "MIT",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/hlucas13/fala-tina/issues"
    },
    "homepage": "https://hlucas13.github.io/fala-tina/",
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "esbuild": "^0.27.4",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3"
    }
