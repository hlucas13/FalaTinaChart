{
    "name": "falatina",
    "version": "1.0.0",
    "description": "Gráfico de mensagens semanais do grupo Fala Tina no WhatsApp — estética Liquid Glass com física de refração.",
    "main": "app.bundle.js",
    "scripts": {
        "build": "node build.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "test": "echo \"Error: no test specified\" && exit 1",
        "prepare": "husky"
    },
    "lint-staged": {
